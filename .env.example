# Supabase — paste your project values from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Payment Links — create these in your Stripe dashboard, then paste the URLs here
# https://dashboard.stripe.com/payment-links
VITE_STRIPE_KIT_LINK=       # Editable QR Kit — $29 one-time payment link
VITE_STRIPE_GROWTH_LINK=    # Growth plan — $12/month payment link
